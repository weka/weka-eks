region       = "us-west-2"
cluster_name = "weka-axon-hyperpod-eks"

# Subnets (private subnets recommended)
subnet_ids = [
  "subnet-xxxxxxxxx",
  "subnet-yyyyyyyyy",
]

# SSO role for cluster admin access
admin_role_arn = "arn:aws:iam::123456789012:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO_AdministratorAccess_xxxxxxxxxxxx"

tags = {
  Environment = "dev"
  Project     = "weka-axon-hyperpod"
}
