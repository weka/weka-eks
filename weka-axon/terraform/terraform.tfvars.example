# ------------------------------------------------------------
# WEKA Axon on EKS - terraform.tfvars example
# ------------------------------------------------------------

# Core
region       = "us-west-2"
cluster_name = "weka-axon-eks"

# IAM role ARN to grant cluster-admin via EKS Access Entry (optional)
# admin_role_arn = "arn:aws:iam::<acct-id>:role/AWSReservedSSO_AdministratorAccess_..."
admin_role_arn = null

# Subnets for worker nodes/control plane ENIs
# Use private subnets (recommended)
subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",
  "subnet-yyyyyyyyyyyyyyyyy",
  "subnet-zzzzzzzzzzzzzzzzz",
]

# Prefer SSM access over SSH. Attaches AmazonSSMManagedInstanceCore to node role.
enable_ssm_access = true

# Node groups
# Map allows multiple groups with different settings (system, storage, etc.)
node_groups = {
  system = {
    instance_types = ["m6i.large"]
    desired_size   = 2
    min_size       = 2
    max_size       = 2
    labels = {
      "node-role" = "system"
    }

    ami_type = "AL2023_x86_64_STANDARD"
  }

  storage = {
    instance_types = ["i3en.12xlarge"]
    desired_size   = 6
    min_size       = 6
    max_size       = 6

    # Root volume size (GiB). WEKA data lives on local NVMe.
    disk_size = 200

    # Hop limit 2 required for WEKA operator to access IMDS from pods for ENI management
    imds_hop_limit_2 = true

    ami_type = "AL2023_x86_64_STANDARD"

    # Enable static CPU Manager for DPDK and dedicated CPU allocation
    enable_cpu_manager_static = true

    # 2 MiB hugepages allocated at boot via nodeadm user data.
    # Must cover all WEKA containers per node (drive + compute + client + offsets).
    # See README section 3.2 for calculation details.
    hugepages_count = 6144

    # Disable hyperthreading. When true, core_count must be set.
    # For i3en.12xlarge: 48 vCPU / 2 threads = 24 physical cores
    disable_hyperthreading = true
    core_count             = 24

    # Labels for WEKA operator placement
    labels = {
      "weka.io/supports-backends" = "true"
      "weka.io/supports-clients"  = "true"
    }

    # Taint prevents non-WEKA workloads from scheduling unless they tolerate it
    taints = [{
      key    = "weka.io/axon"
      value  = "true"
      effect = "NO_SCHEDULE"
    }]
  }
}

# Tags
tags = {
  Environment = "dev"
  Project     = "weka-eks"
  Owner       = "Platform Team"
}

# ------------------------------------------------------------
# IRSA for WEKA operator/controller (ensure-nics)
# ------------------------------------------------------------
enable_weka_operator_irsa = true

# If your operator runs in a different namespace/SA, update these
weka_operator_namespace       = "weka-operator-system"
weka_operator_service_account = "weka-operator-controller-manager"

# Restrict ENI operations to tagged resources (requires controller to tag ENIs)
enforce_eni_tag_conditions = false
eni_tag_key                = "weka.io/cluster"
eni_tag_value              = null

# ------------------------------------------------------------
# Optional cluster settings
# ------------------------------------------------------------
kubernetes_version      = "1.33"
endpoint_private_access = true
endpoint_public_access  = true
public_access_cidrs     = ["0.0.0.0/0"] # tighten to your IP(s) if possible

# Kubelet cluster DNS. Leave null to use EKS defaults (recommended).
cluster_dns_ip = null

# Optional: self-referencing SG for WEKA node-to-node communication
# create_weka_nodes_security_group = false
