# See modules/eks/README.md for the full list of variables.

region       = "us-west-2"
cluster_name = "weka-axon-eks"

subnet_ids = [
  "subnet-xxxxxxxxx",
  "subnet-yyyyyyyyy",
  "subnet-zzzzzzzzz",
]

# Additional security groups to attach to nodes (optional)
# additional_security_group_ids = ["sg-xxxxxxxxx"]

# SSO role for cluster admin access (use full path for SSO roles)
# Format: arn:aws:iam::ACCOUNT:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO_RoleName_xxxx
admin_role_arn = "arn:aws:iam::123456789012:role/aws-reserved/sso.amazonaws.com/AWSReservedSSO_AdministratorAccess_xxxxxxxxxxxx"

node_groups = {
  system = {
    instance_types = ["m6i.large"]
    desired_size   = 2
    min_size       = 2
    max_size       = 2
    labels = {
      "node-role" = "system"
    }
  }

  axon = {
    instance_types            = ["i3en.12xlarge"]
    desired_size              = 6
    min_size                  = 6
    max_size                  = 6
    subnet_ids                = ["subnet-xxxxxxxxx"] # Single AZ for intra-node traffic performance
    disk_size                 = 200
    imds_hop_limit_2          = true
    enable_cpu_manager_static = true
    disable_hyperthreading    = true # For i3en.12xlarge: 48 vCPU / 2 threads = 24 physical cores
    core_count                = 24
    hugepages_count           = 10240
    labels = {
      "weka.io/supports-backends" = "true"
      "weka.io/supports-clients"  = "true"
    }
    taints = [{
      key    = "weka.io/axon"
      value  = "true"
      effect = "NO_SCHEDULE"
    }]
  }
}

tags = {
  Environment = "dev"
  Project     = "weka-on-eks"
}
